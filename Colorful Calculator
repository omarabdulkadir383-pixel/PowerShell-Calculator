#start Menu

Function Main-Menu
{
    Write-Host "*****Calculator*****" -ForegroundColor Cyan
    Write-Host "Press 1 for Addition" -ForegroundColor White
    Write-Host "Press 2 for Subtraction" -ForegroundColor Magenta
    Write-Host "Press 3 for Multiplication" -ForegroundColor DarkCyan
    Write-Host "Press 4 for Division" -ForegroundColor Yellow
    Write-Host "Press 5 for Exit" -ForegroundColor Red
}


#Start Function
Function Addition
{
    $Num1, $Num2 = Get-Numbers
    $Sum = $Num1 + $Num2
    Write-Host "The sum is " $Sum -ForegroundColor DarkBlue
}
Function Subtraction
{
    $num1, $num2 = Get-Numbers
    $Diff = $num1 - $num2
    Write-Host "The Difference is " $Diff -ForegroundColor Magenta
}
Function Multiplication
{
    $Num1, $num2 = Get-Numbers
    $Result = $num1 * $num2
    Write-Host "The result is " $Result -ForegroundColor DarkCyan
}
Function Division
{
    $num1, $num2 = Get-Numbers
    $Total = $num1 / $num2
    Write-Host "The total is " $Total -ForegroundColor Yellow
}

function Get-Numbers
{
    # 1. First number prompt
    Write-Host "Enter the first number: " -ForegroundColor DarkGreen -NoNewline
    [int]$num1 = Read-Host

    # 2. Second number prompt
    Write-Host "Enter the second number: " -ForegroundColor DarkYellow -NoNewline
    [int]$num2 = Read-Host

    return $num1, $num2
}
